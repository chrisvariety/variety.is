---
/* prettier-ignore */
/* @formatter:off */
interface Props {
  species: string;
  eye: string;
  hat: string;
  /** Unique ID for this sprite instance (needed for animation grouping) */
  id?: string;
  class?: string;
}

const { species, eye, hat, id, class: className } = Astro.props;

// --- Sprite data (from sprites.ts) ---
const E = "{E}";
const BODIES: Record<string, string[][]> = {
