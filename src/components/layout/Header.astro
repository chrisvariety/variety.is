				<linearGradient id="logo-g" gradientUnits="userSpaceOnUse" x1="155.42" x2="155.42" xlink:href="#logo-a" y1="34.4397" y2="366.8"/>
				<linearGradient id="logo-h" gradientUnits="userSpaceOnUse" x1="89.6198" x2="89.6198" xlink:href="#logo-a" y1="69.1402" y2="331.4"/>
				<linearGradient id="logo-i" gradientUnits="userSpaceOnUse" x1="60.3201" x2="60.3201" xlink:href="#logo-a" y1="28.0003" y2="196.32"/>
