{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "tabWidth": 2,
  "semi": true,
  "printWidth": 100,
  "singleQuote": false,
  "endOfLine": "lf",
  "trailingComma": "all",
  "sortImports": {},
  "sortTailwindcss": {
    "stylesheet": "./src/styles/global.css",
    "attributes": ["class", "className"],
    "functions": ["clsx", "cn", "cva", "tw"]
  },
  "sortPackageJson": true,
  "ignorePatterns": [
    "pnpm-lock.yaml",
    "package-lock.json",
    "yarn.lock",
    "bun.lock",
    ".astro/",
    ".vercel",
    ".netlify",
    ".cache",
    "dist"
  ]
}
