             ['            ',`    (${E}>     `,'     ||     ','   _(__)_   ','    ^^^^    '],
             ['            ',`     (${E}>>   `,'     ||     ','   _(__)_   ','    ^^^^    ']],
  blob:     [['            ','   .----.   ',`  ( ${E}  ${E} )  `,'  (      )  ','   `----\u00B4   '],
             ['            ','  .------.  ',` (  ${E}  ${E}  ) `,' (        ) ','  `------\u00B4  '],
             ['            ','    .--.    ',`   (${E}  ${E})   `,'   (    )   ','    `--\u00B4    ']],
  cat:      [['            ','   /\\_/\\    ',`  ( ${E}   ${E})  `,'  (  \u03C9  )   ','  (")_(")   '],
             ['            ','   /\\_/\\    ',`  ( ${E}   ${E})  `,'  (  \u03C9  )   ','  (")_(")~  '],
             ['            ','   /\\-/\\    ',`  ( ${E}   ${E})  `,'  (  \u03C9  )   ','  (")_(")   ']],
